
# ============================================================
# PROVIDER CONFIGURATION — change only these two lines
# to switch between AI providers for the entire app.
# ============================================================
LLM_PROVIDER=openai          # "openai" or "google"
API_KEY=your-api-key-here    # Your API key for the chosen provider

# ============================================================
# Optional overrides (defaults are set automatically per provider)
# ============================================================
# CHAT_MODEL=gpt-4o-mini           # OpenAI default
# CHAT_MODEL=gemini-2.5-flash      # Google default
# EMBEDDING_MODEL=text-embedding-3-small   # OpenAI default
# EMBEDDING_MODEL=models/text-embedding-004  # Google default
# EMBEDDING_DIMENSIONS=768         # Default for both providers

# ============================================================
# Firecrawl (web crawling)
# ============================================================
USER_AGENT=Firecrawl-Docling-RAG-Agent/1.0
FIRECRAWL_API_KEY=your-firecrawl-api-key-here
# Leave FIRECRAWL_API_URL empty to use cloud API (https://api.firecrawl.dev)
# FIRECRAWL_API_URL=http://localhost:3002   # Uncomment for self-hosted

# ============================================================
# Database
# ============================================================
DATABASE_URL=postgresql://user:password@localhost:5433/firecrawl_docling_db
# DATABASE_URL=postgresql://user:password@pgvector:5432/firecrawl_docling_db  # Docker

# Hugging Face: suppress symlink warning (fixes WinError 1314 on Windows)
HF_HUB_DISABLE_SYMLINKS_WARNING=1
