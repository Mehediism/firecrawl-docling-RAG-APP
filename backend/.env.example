
USER_AGENT=Firecrawl-Docling-RAG-Agent/1.0
GOOGLE_API_KEY=your-google-api-key-here
# ==================== FIRECRAWL CONFIGURATION ====================
# Cloud API (firecrawl.dev) - ACTIVE
FIRECRAWL_API_KEY=your-firecrawl-api-key-here
# Leave FIRECRAWL_API_URL empty/unset to use cloud API (https://api.firecrawl.dev)

# ==================== LOCAL SELF-HOSTED (COMMENTED OUT) ====================
# Uncomment these and comment out the cloud API key above to use local instance
# FIRECRAWL_API_KEY=self-hosted-dummy
# FIRECRAWL_API_URL=http://localhost:3002
# FIRECRAWL_API_URL=http://api:3002 # Use this if running backend inside Docker

DATABASE_URL=postgresql://user:password@localhost:5433/firecrawl_docling_db
# DATABASE_URL=postgresql://user:password@pgvector:5432/firecrawl_docling_db # Use this if running backend inside Docker

# Hugging Face: Suppress symlink warning and use fallback mode (fixes WinError 1314 on Windows)
HF_HUB_DISABLE_SYMLINKS_WARNING=1
